@model IEnumerable<AcademicoAVD2.Models.Instituicao>
@{ ViewData["Title"] = "Instituições"; }

<h1>Instituições</h1>
<p><a asp-action="Create" class="btn btn-primary">Nova Instituição</a></p>
<table class="table table-striped">
    <thead>
        <tr><th>Nome</th><th>Endereço</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>@item.Endereco</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.InstituicaoID" class="btn btn-sm btn-info">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.InstituicaoID" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.InstituicaoID" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
